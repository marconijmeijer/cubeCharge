{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.cubecharge",
  "name": {
    "en": "CubeCharging"
  },
  "description": {
    "en": "Control CubeCharging charge boxes via API."
  },
  "brandColor": "#111111",
  "version": "1.0.0",
  "category": [
    "energy"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "main": "app.js",
  "compatibility": ">=5.0.0",
  "author": {
    "name": "",
    "email": ""
  },
  "permissions": [],
  "sdk": 3,
  "dependencies": {},
  "platforms": [
    "local"
  ],
  "tags": {
    "en": [
      "Cube",
      "Charger",
      ""
    ]
  },
  "flow": {
    "triggers": [
      {
        "id": "cubecharge_status_updated",
        "title": {
          "en": "The connector status changed",
          "nl": "De connectorstatus is bijgewerkt"
        },
        "titleFormatted": {
          "en": "The connector status changed",
          "nl": "De connectorstatus is bijgewerkt"
        },
        "tokens": [
          {
            "name": "status",
            "type": "string",
            "title": {
              "en": "Status",
              "nl": "Status"
            }
          },
          {
            "name": "connector_id",
            "type": "number",
            "title": {
              "en": "Connector ID",
              "nl": "Connector ID"
            }
          },
          {
            "name": "charge_box_id",
            "type": "string",
            "title": {
              "en": "Charge box ID",
              "nl": "Charge box ID"
            }
          },
          {
            "name": "event_type",
            "type": "string",
            "title": {
              "en": "Event type",
              "nl": "Event type"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=chargebox"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "cubecharge_start_charging",
        "title": {
          "en": "Start charging",
          "nl": "Start laden"
        },
        "titleFormatted": {
          "en": "Start charging on connector [[connector_id]] with idTag [[id_tag]]",
          "nl": "Start laden op connector [[connector_id]] met idTag [[id_tag]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=chargebox"
          },
          {
            "type": "number",
            "name": "connector_id",
            "title": {
              "en": "Connector ID",
              "nl": "Connector ID"
            },
            "min": 1,
            "step": 1,
            "placeholder": {
              "en": "1",
              "nl": "1"
            }
          },
          {
            "type": "text",
            "name": "id_tag",
            "title": {
              "en": "idTag",
              "nl": "idTag"
            },
            "placeholder": {
              "en": "RFID123456",
              "nl": "RFID123456"
            }
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "id": "chargebox",
      "name": {
        "en": "CubeCharging Charge Box"
      },
      "class": "other",
      "images": {
        "small": "/drivers/chargebox/assets/images/small.png",
        "large": "/drivers/chargebox/assets/images/large.png",
        "xlarge": "/drivers/chargebox/assets/images/xlarge.png"
      },
      "capabilities": [
        "onoff",
        "cube_connector_status"
      ],
      "pair": [
        {
          "id": "api_key",
          "navigation": {
            "next": "loading"
          }
        },
        {
          "id": "loading"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices",
            "prev": "api_key"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "connectivity": [
        "cloud"
      ],
      "platforms": [
        "local"
      ],
      "settings": [
        {
          "id": "charge_box_id",
          "type": "label",
          "label": {
            "en": "Device ID",
            "nl": "Device ID"
          },
          "value": "",
          "hint": {
            "en": "The CubeCharging charge box ID used by this Homey device.",
            "nl": "Het CubeCharging charge box ID dat door dit Homey-apparaat wordt gebruikt."
          }
        }
      ]
    }
  ],
  "capabilities": {
    "cube_connector_status": {
      "type": "string",
      "title": {
        "en": "Connector status",
        "nl": "Connectorstatus"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "preventInsights": true
    }
  }
}